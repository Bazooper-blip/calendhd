{% comment %}
  calenDHD — full screen (works on TRMNL OG and TRMNL X; the design framework
  scales the layout per device). Left column: right-now focus + today's agenda.
  Right column: the next few days.
{% endcomment %}
{% assign today = days | first %}

<div class="layout">
  <div class="columns">

    <div class="column">
      {% if current_event %}
        <div class="item">
          <div class="content">
            <span class="label label--small">NOW · {{ current_event.left_label }} left</span>
            <span class="title">{% if current_event.icon != blank %}{{ current_event.icon }} {% endif %}{{ current_event.title }}</span>
            <span class="label label--small label--underline">{{ current_event.time_range }}</span>
            {% if current_event.first_step != blank %}
              <span class="description">Start with: {{ current_event.first_step }}</span>
            {% endif %}
          </div>
        </div>
      {% elsif next_event %}
        <div class="item">
          <div class="content">
            <span class="label label--small">NEXT · in {{ next_event.in_label }}{% unless next_event.day_label == today.label %} ({{ next_event.day_label }}){% endunless %}</span>
            <span class="title">{% if next_event.icon != blank %}{{ next_event.icon }} {% endif %}{{ next_event.title }}</span>
            <span class="label label--small label--underline">{{ next_event.time_range }}</span>
          </div>
        </div>
      {% else %}
        <div class="item">
          <div class="content">
            <span class="label label--small">NOW</span>
            <span class="title">Nothing scheduled</span>
            <span class="description">Enjoy the calm.</span>
          </div>
        </div>
      {% endif %}

      {% if tasks_total_today > 0 %}
        <span class="label label--small">✓ {{ tasks_done_today }} of {{ tasks_total_today }} done today</span>
      {% endif %}

      <div class="list" data-list-limit="true" data-list-max-height="300" data-list-hidden-count="true">
        {% for ev in today.all_day %}
          <div class="item">
            <div class="content">
              <span class="title title--small">{% if ev.icon != blank %}{{ ev.icon }} {% endif %}{{ ev.title }}</span>
              <span class="label label--small">All day{% if ev.source != blank %} · {{ ev.source }}{% endif %}</span>
            </div>
          </div>
        {% endfor %}
        {% for ev in today.events %}
          <div class="item">
            <div class="content">
              <span class="title title--small">{% if ev.is_task %}{% if ev.done %}✓ {% else %}○ {% endif %}{% endif %}{% if ev.icon != blank %}{{ ev.icon }} {% endif %}{{ ev.title }}</span>
              <span class="label label--small label--underline">{{ ev.time_range }}{% if ev.routine != blank %} · {{ ev.routine }}{% elsif ev.category != blank %} · {{ ev.category }}{% elsif ev.source != blank %} · {{ ev.source }}{% endif %}</span>
            </div>
          </div>
        {% endfor %}
        {% if today.event_count == 0 %}
          <div class="item">
            <div class="content">
              <span class="description">No events today</span>
            </div>
          </div>
        {% endif %}
      </div>
      {% if today.more_count > 0 %}
        <span class="label label--small">+{{ today.more_count }} more</span>
      {% endif %}
    </div>

    <div class="column">
      <div class="list" data-list-limit="true" data-list-max-height="440" data-list-hidden-count="true">
        {% for day in days offset: 1 %}
          <div class="item">
            <div class="content">
              <span class="label label--small label--underline">{{ day.label }} · {{ day.date_label }}</span>
            </div>
          </div>
          {% for ev in day.all_day limit: 2 %}
            <div class="item">
              <div class="content">
                <span class="title title--small">{% if ev.icon != blank %}{{ ev.icon }} {% endif %}{{ ev.title }}</span>
                <span class="label label--small">All day</span>
              </div>
            </div>
          {% endfor %}
          {% for ev in day.events limit: 4 %}
            <div class="item">
              <div class="content">
                <span class="title title--small">{% if ev.icon != blank %}{{ ev.icon }} {% endif %}{{ ev.title }}</span>
                <span class="label label--small">{{ ev.time }}{% if ev.source != blank %} · {{ ev.source }}{% endif %}</span>
              </div>
            </div>
          {% endfor %}
        {% endfor %}
      </div>
    </div>

  </div>
</div>

<div class="title_bar">
  <img class="image" src="https://usetrmnl.com/images/plugins/trmnl--render.svg" />
  <span class="title">calenDHD</span>
  <span class="instance">{{ today_label }}</span>
</div>
