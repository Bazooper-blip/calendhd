# PocketBase Configuration
VITE_POCKETBASE_URL=http://127.0.0.1:8090
POCKETBASE_URL=http://127.0.0.1:8090

# Optional: PocketBase encryption key for Docker deployment
PB_ENCRYPTION_KEY=

# Optional: Apple OAuth Configuration (for Sign in with Apple)
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

# Optional: Push Notifications (Web Push / VAPID)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
