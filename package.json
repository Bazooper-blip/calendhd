{
  "name": "calendhd",
  "version": "1.0.0",
  "description": "A calm, ADHD-friendly calendar PWA for neurodivergent minds",
  "private": true,
  "type": "module",
  "license": "MIT",
  "author": "",
  "repository": {
    "type": "git",
    "url": ""
  },
  "keywords": [
    "calendar",
    "pwa",
    "adhd",
    "neurodivergent",
    "svelte",
    "sveltekit",
    "pocketbase"
  ],
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "test": "vitest",
    "test:e2e": "playwright test",
    "lint": "biome check src && svelte-check --tsconfig ./tsconfig.json",
    "format": "biome format --write src",
    "format:check": "biome format src"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@playwright/test": "^1.60.0",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.63.1",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^25.9.2",
    "fake-indexeddb": "^6.2.5",
    "svelte": "^5.56.3",
    "svelte-check": "^4.6.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "bits-ui": "^2.18.1",
    "date-fns": "^4.4.0",
    "date-fns-tz": "^3.2.0",
    "dexie": "^4.4.3",
    "lucide-svelte": "^1.0.1",
    "pocketbase": "^0.27.0",
    "svelte-i18n": "^4.0.1",
    "svelte-sonner": "^1.1.1"
  },
  "overrides": {
    "cookie": "^0.7.2",
    "svelte-i18n": {
      "esbuild": "^0.25.0"
    }
  },
  "engines": {
    "node": ">=20"
  }
}
